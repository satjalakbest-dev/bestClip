# bestClip Environment Variables
# Copy this file to .env and fill in your keys

# ── Required ──────────────────────────────────────────
# Anthropic Claude API key (for script generation)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional ──────────────────────────────────────────
# Google Gemini API (for research step)
# Get from: https://aistudio.google.com
GOOGLE_API_KEY=AIza...

# ── Settings ──────────────────────────────────────────
# TTS Engine: edge (default, free) or f5 (local GPU)
TTS_ENGINE=edge

# Edge-TTS voice options:
# Male  : th-TH-NiwatNeural
# Female: th-TH-PremwadeeNeural
TTS_VOICE=th-TH-NiwatNeural

# ComfyUI API URL (for FLUX.1 image generation)
COMFYUI_URL=http://127.0.0.1:8188

# Channel name shown in video
CHANNEL_NAME=Your Channel Name
